# Environment Variables

# Vercel KV (optional but recommended for production)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Google Sheets Webhook (optional - set up a Google Form or Zapier webhook)
GOOGLE_SHEETS_WEBHOOK_URL=

# WhatsApp Number (without + or country code)
WHATSAPP_NUMBER=

# Admin credentials (for admin.js if needed)
ADMIN_PASSWORD=
